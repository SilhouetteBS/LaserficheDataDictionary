{
  "name": "laserfiche-db-dictionary",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:editing": "node tools/dev-editing.mjs",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "render:check": "node tools/render-check.mjs",
    "import:forms": "node tools/import-forms-metadata.mjs",
    "import:schema": "node tools/import-forms-metadata.mjs",
    "lint": "eslint .",
    "test": "node tools/run-tests.mjs",
    "test:unit": "node tools/run-tests.mjs",
    "test:e2e": "node tools/e2e-smoke.mjs",
    "test:diagram": "node tools/diagram-regression.mjs",
    "test:visual": "node tools/visual-regression-screenshots.mjs",
    "test:static-build": "node tools/static-build-smoke.mjs",
    "audit:accessibility": "node tools/accessibility-audit.mjs",
    "audit:performance": "node tools/performance-budget.mjs",
    "validate:data": "node tools/validate-data.mjs",
    "validate:notes": "node tools/validate-notes.mjs",
    "verify:lockfile": "node tools/verify-lockfile.mjs",
    "verify:static-security": "node tools/verify-static-security.mjs",
    "test:editing-guard": "node tools/verify-editing-guard.mjs",
    "audit:dependencies": "npm audit --audit-level=high",
    "release-notes:draft": "node tools/generate-release-notes.mjs",
    "verify:public-build": "node tools/verify-public-build.mjs",
    "verify:deployed-site": "node tools/verify-deployed-site.mjs",
    "validate": "npm run lint && npm run test:unit && npm run test:diagram && npm run validate:data && npm run validate:notes && npm run verify:lockfile && npm run verify:static-security && npm run build && npm run test:static-build && npm run audit:performance && npm run render:check",
    "validate:full": "npm run validate && npm run test:e2e"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "playwright": "^1.61.0"
  }
}
